{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/uploads/:path*"
    },
    {
      "source": "/((?!assets/|vite.svg|favicon.ico).*)*",
      "destination": "/index.html"
    }
  ]
}
